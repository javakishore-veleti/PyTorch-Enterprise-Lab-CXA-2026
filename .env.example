# QuantEdge Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to version control.

# ── API Security ─────────────────────────────────────────────────────────────
QUANTEDGE_API_KEY=dev-insecure-key-change-in-prod

# ── MLflow Tracking ───────────────────────────────────────────────────────────
# Local:       http://localhost:5000
# Remote:      https://mlflow.your-org.com
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Model Registry Backend ────────────────────────────────────────────────────
# Options:     mlflow | sagemaker | azureml
MODEL_REGISTRY_BACKEND=mlflow

# ── AWS (SageMaker) ───────────────────────────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SAGEMAKER_ROLE_ARN=

# ── Azure ML ──────────────────────────────────────────────────────────────────
# AZUREML_WORKSPACE=
# AZUREML_SUBSCRIPTION_ID=
# AZUREML_RESOURCE_GROUP=

# ── PostgreSQL (local Docker via DevOps/Local/postgres/docker-compose.yml) ───
DATABASE_URL=postgresql://quantedge:quantedge@localhost:5432/quantedge

# ── Data directories ─────────────────────────────────────────────────────────
FOREX_DATA_DIR=./data/forex
CFPB_DATA_DIR=./data/cfpb

# ── HuggingFace ───────────────────────────────────────────────────────────────
# HF_TOKEN=               # Required for private datasets/models
# HF_HUB_CACHE=           # Override default cache location
